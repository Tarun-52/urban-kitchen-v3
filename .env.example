# ═══════════════════════════════════════════
# Urban Kitchen - Production Environment
# ═══════════════════════════════════════════

# Database (SQLite - relative path from app root)
DATABASE_URL=file:./db/custom.db

# Application
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Optional: Email (for contact form / notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@urbankitchens.com
# EMAIL_FROM=noreply@urbankitchens.com
# BUSINESS_EMAIL=sales@urbankitchens.com

# Optional: Google Maps (for employee live location)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
