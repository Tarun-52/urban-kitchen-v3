generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  phone           String?
  password        String
  roleId          String
  status          String           @default("active")
  emailVerified   Boolean          @default(false)
  avatar          String?
  canManageBlogs  Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  activityLogs    ActivityLog[]
  amcContracts    AmcContract[]
  blogPosts       BlogPost[]
  cartItems       CartItem[]
  employee        Employee?
  assignedLeads   Lead[]           @relation("AssignedLeads")
  orders          Order[]
  assignedDeals   PipelineDeal[]   @relation("DealAssignee")
  assignedTickets ServiceRequest[] @relation("AssignedTechnician")
  serviceRequests ServiceRequest[]
  role            Role             @relation(fields: [roleId], references: [id])
  wishlistItems   WishlistItem[]
}

model Role {
  id          String @id @default(cuid())
  roleName    String @unique
  permissions String @default("[]")
  users       User[]
}

model Category {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  description    String?
  displayType    String     @default("products")
  menuOrder      Int        @default(0)
  image          String?
  thumbnail      String?
  bannerImage    String?
  seoTitle       String?
  seoDescription String?
  status         String     @default("active")
  parentId       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  parent         Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       Category[] @relation("CategoryHierarchy")
  products       Product[]
}

model Product {
  id               String           @id @default(cuid())
  categoryId       String
  name             String
  slug             String           @unique
  description      String
  shortDescription String?
  longDescription  String?
  price            Float
  steelGrade       String?
  capacity         String?
  dimensions       String?
  stock            Int              @default(0)
  moq              Int              @default(1)
  leadTime         String?
  featuredImage    String?
  status           String           @default("active")
  featured         Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  cartItems        CartItem[]
  orderItems       OrderItem[]
  category         Category         @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
  variants         ProductVariant[]
  wishlist         WishlistItem[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  image     String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  name       String
  sku        String?
  price      Float
  stock      Int         @default(0)
  weight     String?
  dimensions String?
  isDefault  Boolean     @default(false)
  sortOrder  Int         @default(0)
  cartItems  CartItem[]
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  customerId      String
  orderNumber     String      @unique
  subtotal        Float
  tax             Float       @default(0)
  shipping        Float       @default(0)
  total           Float
  paymentStatus   String      @default("pending")
  paymentMethod   String?
  orderStatus     String      @default("pending")
  shippingAddress String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  customer        User        @relation(fields: [customerId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  qty       Int
  price     Float
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  product   Product         @relation(fields: [productId], references: [id])
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model CartItem {
  id        String          @id @default(cuid())
  userId    String
  productId String
  variantId String?
  qty       Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  product   Product         @relation(fields: [productId], references: [id])
  user      User            @relation(fields: [userId], references: [id])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model Lead {
  id          String         @id @default(cuid())
  name        String
  company     String?
  phone       String?
  email       String?
  city        String?
  requirement String?
  message     String?
  status      String         @default("new")
  source      String?
  assignedTo  String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  companyId   String?
  companyRef  Company?       @relation(fields: [companyId], references: [id])
  assignee    User?          @relation("AssignedLeads", fields: [assignedTo], references: [id])
  deals       PipelineDeal[]
  quotations  Quotation[]
}

model Quotation {
  id              String    @id @default(cuid())
  leadId          String?
  quotationNumber String    @unique
  amount          Float
  customerName    String    @default("N/A")
  customerCompany String?
  customerEmail   String?
  customerPhone   String?
  customerAddress String?
  customerGst     String?
  items           String?
  subtotal        Float     @default(0)
  cgstAmount      Float     @default(0)
  sgstAmount      Float     @default(0)
  igstAmount      Float     @default(0)
  discountAmount  Float     @default(0)
  totalGst        Float     @default(0)
  notes           String?
  terms           String?
  bankDetails     String?
  validUntil      DateTime?
  status          String    @default("draft")
  deliveryPeriod  String?
  installation    String?
  warranty        String?
  emailSent       Boolean   @default(false)
  emailSentAt     DateTime?
  whatsappSent    Boolean   @default(false)
  whatsappSentAt  DateTime?
  pdf             String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lead            Lead?     @relation(fields: [leadId], references: [id])
}

model Employee {
  id                 String              @id @default(cuid())
  userId             String              @unique
  department         String
  designation        String
  salary             Float
  joiningDate        DateTime
  status             String              @default("active")
  bankDetails        String?
  documents          String?
  appraisals         Appraisal[]
  assets             Asset[]
  attendance         Attendance[]
  dailyFieldWorks    DailyFieldWork[]
  user               User                @relation(fields: [userId], references: [id])
  leaves             Leave[]
  performanceReviews PerformanceReview[]
  salarySlips        SalarySlip[]
  tasks              Task[]
  workReports        WorkReport[]
}

model EmployeeLocation {
  id         String   @id @default(cuid())
  employeeId String
  latitude   Float
  longitude  Float
  timestamp  DateTime @default(now())
}

model Attendance {
  id                String    @id @default(cuid())
  employeeId        String
  date              DateTime
  checkin           DateTime?
  checkout          DateTime?
  status            String    @default("present")
  checkinLatitude   Float?
  checkinLongitude  Float?
  checkinAddress    String?
  checkoutLatitude  Float?
  checkoutLongitude Float?
  checkoutAddress   String?
  source            String?   @default("web")
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  employeeId  String
  title       String
  description String?
  priority    String    @default("medium")
  status      String    @default("pending")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model SalarySlip {
  id         String   @id @default(cuid())
  employeeId String
  month      String
  basic      Float
  hra        Float    @default(0)
  allowance  Float    @default(0)
  deduction  Float    @default(0)
  netPay     Float
  pdf        String?
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Leave {
  id         String   @id @default(cuid())
  employeeId String
  type       String
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AmcContract {
  id              String           @id @default(cuid())
  customerId      String
  plan            String
  startDate       DateTime
  endDate         DateTime
  amount          Float
  status          String           @default("active")
  coverage        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customer        User             @relation(fields: [customerId], references: [id])
  serviceRequests ServiceRequest[]
}

model ServiceRequest {
  id                 String       @id @default(cuid())
  customerId         String
  contractId         String?
  issue              String
  priority           String       @default("medium")
  assignedTechnician String?
  status             String       @default("open")
  resolution         String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  technician         User?        @relation("AssignedTechnician", fields: [assignedTechnician], references: [id])
  contract           AmcContract? @relation(fields: [contractId], references: [id])
  customer           User         @relation(fields: [customerId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  productId String?
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model AmcQuote {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  company       String?
  plan          String
  equipmentList String?
  kitchenSize   String?
  city          String?
  message       String?
  status        String   @default("new")
  emailSent     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Company {
  id        String   @id @default(cuid())
  name      String
  industry  String?
  website   String?
  phone     String?
  email     String?
  address   String?
  gstNumber String?
  revenue   Float    @default(0)
  status    String   @default("prospect")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leads     Lead[]
}

model Pipeline {
  id          String         @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean        @default(false)
  stages      String         @default("[]")
  status      String         @default("active")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deals       PipelineDeal[]
}

model PipelineDeal {
  id          String    @id @default(cuid())
  pipelineId  String
  leadId      String?
  title       String
  value       Float     @default(0)
  stage       String
  probability Int       @default(50)
  assigneeId  String?
  closeDate   DateTime?
  status      String    @default("open")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  assignee    User?     @relation("DealAssignee", fields: [assigneeId], references: [id])
  lead        Lead?     @relation(fields: [leadId], references: [id])
  pipeline    Pipeline  @relation(fields: [pipelineId], references: [id])
}

model EmailTemplate {
  id         String   @id @default(cuid())
  name       String
  subject    String
  body       String
  category   String   @default("general")
  variables  String   @default("[]")
  usageCount Int      @default(0)
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EmailSequence {
  id          String                    @id @default(cuid())
  name        String
  description String?
  triggerType String                    @default("manual")
  status      String                    @default("active")
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  enrollments EmailSequenceEnrollment[]
  steps       EmailSequenceStep[]
}

model EmailSequenceStep {
  id         String        @id @default(cuid())
  sequenceId String
  templateId String?
  subject    String
  body       String
  delayDays  Int           @default(0)
  order      Int           @default(0)
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
}

model EmailSequenceEnrollment {
  id          String        @id @default(cuid())
  sequenceId  String
  leadId      String?
  leadEmail   String
  currentStep Int           @default(0)
  status      String        @default("active")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  sequence    EmailSequence @relation(fields: [sequenceId], references: [id])
}

model LeadSource {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("organic")
  cost      Float    @default(0)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Integration {
  id        String    @id @default(cuid())
  name      String
  category  String    @default("crm")
  config    String    @default("{}")
  status    String    @default("disconnected")
  lastSync  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Conversation {
  id         String                @id @default(cuid())
  leadId     String?
  channel    String                @default("email")
  subject    String?
  status     String                @default("open")
  assigneeId String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  messages   ConversationMessage[]
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderType     String       @default("contact")
  senderName     String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model CrmForm {
  id          String   @id @default(cuid())
  name        String
  fields      String   @default("[]")
  submissions Int      @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CrmImport {
  id         String   @id @default(cuid())
  fileName   String
  source     String   @default("csv")
  records    Int      @default(0)
  successful Int      @default(0)
  failed     Int      @default(0)
  status     String   @default("pending")
  errors     String?
  createdAt  DateTime @default(now())
}

model Department {
  id        String   @id @default(cuid())
  name      String
  head      String?
  budget    Float    @default(0)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Designation {
  id        String   @id @default(cuid())
  name      String
  level     Int      @default(1)
  minSalary Float    @default(0)
  maxSalary Float    @default(0)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holiday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  type      String   @default("public")
  createdAt DateTime @default(now())
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  priority  String   @default("normal")
  postedBy  String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobOpening {
  id           String   @id @default(cuid())
  title        String
  department   String
  type         String   @default("full-time")
  experience   String?
  salaryRange  String?
  description  String?
  requirements String?
  location     String?
  status       String   @default("open")
  applications Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Interview {
  id             String   @id @default(cuid())
  candidateName  String
  candidateEmail String?
  candidatePhone String?
  position       String
  date           DateTime
  interviewer    String?
  rating         Float    @default(0)
  feedback       String?
  status         String   @default("scheduled")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PerformanceReview {
  id         String   @id @default(cuid())
  employeeId String
  reviewerId String?
  period     String
  score      Float    @default(0)
  goals      String?
  feedback   String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Appraisal {
  id          String   @id @default(cuid())
  employeeId  String
  cycle       String
  rating      Float    @default(0)
  hikePercent Float    @default(0)
  newSalary   Float    @default(0)
  comments    String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model TrainingProgram {
  id        String    @id @default(cuid())
  name      String
  type      String    @default("internal")
  duration  String?
  trainer   String?
  enrolled  Int       @default(0)
  maxSeats  Int       @default(0)
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("upcoming")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Asset {
  id           String    @id @default(cuid())
  name         String
  type         String    @default("electronics")
  serialNo     String?
  value        Float     @default(0)
  assignedTo   String?
  purchaseDate DateTime?
  status       String    @default("available")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignee     Employee? @relation(fields: [assignedTo], references: [id])
}

model Shift {
  id            String   @id @default(cuid())
  name          String
  startTime     String
  endTime       String
  breakDuration Int      @default(30)
  employees     Int      @default(0)
  supervisor    String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkReport {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime
  hours      Float    @default(8)
  tasks      String?
  summary    String?
  status     String   @default("submitted")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model DailyFieldWork {
  id              String    @id @default(cuid())
  employeeId      String
  date            DateTime
  workType        String    @default("site_visit")
  title           String
  description     String?
  latitude        Float?
  longitude       Float?
  address         String?
  clientName      String?
  clientPhone     String?
  clientCompany   String?
  followUpDate    DateTime?
  followUpNote    String?
  followUpCreated Boolean   @default(false)
  pipelineDealId  String?
  pipelineCreated Boolean   @default(false)
  status          String    @default("completed")
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Team {
  id         String   @id @default(cuid())
  name       String
  leadId     String?
  members    Int      @default(0)
  department String?
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  message   String
  type      String   @default("info")
  link      String?
  linkId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BlogCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  emoji       String?
  color       String?
  sortOrder   Int        @default(0)
  status      String     @default("active")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  posts       BlogPost[]
}

model BlogPost {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String?
  content        String
  featuredImage  String?
  categoryId     String?
  category       String?
  tags           String?
  authorId       String?
  status         String        @default("draft")
  featured       Boolean       @default(false)
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  author         User?         @relation(fields: [authorId], references: [id])
  categoryRef    BlogCategory? @relation(fields: [categoryId], references: [id])
}
